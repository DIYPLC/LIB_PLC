FUNCTION_BLOCK FbEdgePos (* Детектор нарастающего фронта. *)

VAR_INPUT
	In :BOOL := FALSE; (* Вход. *)
END_VAR

VAR_OUTPUT
	Out :BOOL := FALSE; (* Выход. *)
END_VAR

VAR
	In_previos :BOOL := FALSE; (* Предыдущее состояние входа. *)
END_VAR
(* @END_DECLARATION := '0' *)
(*
 Детектор нарастающего фронта.
       DbEdgePos
     +-----------+
     | FbEdgePos |
  ->-|In      Out|->-
     +-----------+
*)

(* Детектор нарастающего фронта. *)
Out := In AND NOT(In_previos);
(* Запомнить предыдущее состояние входа. *)
In_previos := In;

