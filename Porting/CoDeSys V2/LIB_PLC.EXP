(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
FUNCTION_BLOCK FbTask1 (* Пример использования библиотеки. *)
VAR_INPUT
	Ts_ms: UDINT := 0;
	Ts: REAL := 0.0; (*Шаг дискретизации по времени в секундах.*)
	Reset: BOOL := TRUE;
END_VAR
VAR_OUTPUT
	DbGSS: FbGSS;
END_VAR
VAR
	Timer1_ms: UDINT:= 0;
	Integrator1_s: REAL:= 0;
	Blink: BOOL := FALSE;
	DbBlink: FbBlink; (* Мигающий светодиод. *)
	DbPIDcontrol:FbPIDcontrol; (* ПИД-регулятор. *)
	Db2oo3: Fb2oo3;
	Db2PosControl: Fb2PosControl;
	Db3PosControl: Fb3PosControl;
	DbAlarm: FbAlarm;
	DbReadMe: ReadMe;
	DbBitsToWord: FbBitsToWord;
	DbCounter: FbCounter;
	DbDeadBand: FbDeadBand;
	DbDelayN: FbDelayN;
	DbDeriveF: FbDeriveF;
	DbDispersion: FbDispersion;
	DbDriverAi420: FbDriverAi420;
	DbDriverAo420: FbDriverAo420;
	DbDriverDi: FbDriverDi;
	DbDriverDo: FbDriverDo;
	DbEdgeNeg: FbEdgeNeg;
	DbEdgePos: FbEdgePos;
	DbFilterA: FbFilterA;
	DbFilterM: FbFilterM;
	DbFilterNaN: FbFilterNaN;
	DbIntegrator: FbIntegrator;
	DbLimit: FbLimit;
	DbModeSelector: FbModeSelector;
	DbMotor: FbMotor;
	DbPIDstep: FbPIDstep;
	DbRamp: FbRamp;
	DbScale: FbScale;
	DbSimMotorGear: FbSimMotorGear;
	DbSoftPWM: FbSoftPWM;
	DbStpForPD: FbStpForPD;
	DbSum1bit: FbSum1bit;
	DbTOF: FbTOF;
	DbTON: FbTON;
	DbTriggerRS: FbTriggerRS;
	DbWordToBits: FbWordToBits;
	DbValve: FbValve;
END_VAR
(* @END_DECLARATION := '0' *)
(*  Мигающий светодиод.
            DbBlink 
    +---------------------+
    |       FbBlink       |
   -|TimeOn      BlinkLamp|->-
   -|TimeOff              |
   -|Ts_ms                |
   -|Reset                |
    +---------------------+    *)
DbBlink.TimeOn   := 500              ; (* Время включения лампочки [мс]. *)
DbBlink.TimeOff  := 500              ; (* Время выключения лампочки [мс]. *)
DbBlink.Ts_ms    := Ts_ms            ; (* Шаг дискретизации по времени [мс]. *)
DbBlink.Reset    := Reset            ; (* Сброс при перезагрузке. *)
DbBlink()                            ;
%MX0.0           := DbBlink.BlinkLamp; (* Мигающая лампочка. *)

(* Пример моргания светодиодом №2. *)
IF (Timer1_ms >= 10*1000) OR Reset THEN (* Период 10с. *)
Timer1_ms := 0;
ELSE
Timer1_ms := Timer1_ms + Ts_ms;
END_IF;
Blink := (Timer1_ms <= 5*1000); (* Время импульса 5с. *)

(* Пример построения интегратора. *)
(* Реакция интегратора на единичное ступенчатое воздействие. *)
Integrator1_s := Integrator1_s + 1.0 * Ts;

(* Пример проверки работоспособности регулятора. *)
DbPIDcontrol.PV := DbPIDcontrol.MV;
DbPIDcontrol.SP := 50;
DbPIDcontrol.Ki := 0.1;
DbPIDcontrol.Ts := Ts;
DbPIDcontrol();

(* test call *)
Db2oo3();
Db2PosControl();
Db3PosControl();
DbAlarm();
DbReadMe();
DbBitsToWord();
DbCounter();
DbDeadBand();
DbDelayN();
DbDeriveF();
DbDispersion();
DbDriverAi420();
DbDriverAo420();
DbDriverDi();
DbDriverDo();
DbEdgeNeg();
DbEdgePos();
DbFilterA();
DbFilterM();
DbFilterNaN();
DbGSS.Ts := Ts;
DbGSS();
DbIntegrator();
DbLimit();
DbModeSelector();
DbMotor();
DbPIDstep();
DbRamp();
DbScale();
DbSimMotorGear();
DbSoftPWM();
DbStpForPD();
DbSum1bit();
DbTOF();
DbTON();
DbTriggerRS();
DbWordToBits();
DbValve();







END_FUNCTION_BLOCK


(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '4096' *)
PROGRAM PLC_PRG
VAR
	Uptime_ms: UDINT := 0;
	Ts_max_ms: UDINT := 0;
	Ts_ms: UDINT := 0;
	Ts: REAL := 0.0; (*Шаг дискретизации по времени в секундах.*)
	Reset: BOOL := TRUE;
	millis_ms: UDINT := 0;
	millis_previuos_ms: UDINT:= 0;
	DbTask1:FbTask1;
END_VAR
(* @END_DECLARATION := '0' *)
(* Данное условие должно быть в начале PLC_PRG. *)
IF Reset THEN
millis_ms := DWORD_TO_DINT(TIME_TO_DWORD(TIME()));
millis_previuos_ms := millis_ms;
Ts_ms := 0;
Ts_max_ms := 0;
Uptime_ms := 0;
ELSE
	millis_ms := TIME_TO_UDINT(TIME());
	IF (millis_ms >= millis_previuos_ms) THEN
	Ts_ms := millis_ms - millis_previuos_ms;
	ELSE
	; (* В данном случае исходим из того что врямя скана меняется не значительно. *)
	END_IF;
	millis_previuos_ms := millis_ms;
END_IF;

Uptime_ms := Uptime_ms + Ts_ms;
IF (Ts_ms > Ts_max_ms) THEN
Ts_max_ms := Ts_ms;
END_IF
Ts := UDINT_TO_REAL(Ts_ms) * 0.001;

DbTask1.Ts_ms := Ts_ms;
DbTask1.Ts := Ts;
DbTask1.Reset := Reset;
DbTask1();

(* Данное условие должно быть в конце PLC_PRG. *)
IF Reset THEN
Reset := FALSE;
END_IF;
END_PROGRAM


