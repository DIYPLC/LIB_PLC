(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/LIB_PLC' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
FUNCTION_BLOCK FbDeriveF (* Производная с фильтром. *)

VAR_INPUT
	In  :REAL := 0.0; (* Входной сигнал. *)
	Kdf :REAL := 1.0; (* Коэффициент фильтрации дифференциальный Kdf=1/Tdf. *)
	Ts  :REAL := 0.1; (* Шаг дискретизации по времени [с]. *)
END_VAR

VAR_OUTPUT
	Out :REAL := 0.0; (* Выходной сигнал. *)
END_VAR

VAR
	Dintegral :REAL := 0.0; (* Интегратор. *)
END_VAR
(* @END_DECLARATION := '0' *)
(*
 Производная с фильтром.
      DbDeriveF
    +-----------+
    | FbDeriveF |
 ->-|In      Out|->-
   -|Kdf        |
   -|Ts         |
    +-----------+
*)

(* W(s)=s/(1+Tdf*s) при Tdf=1/Kdf и Ts->0. *)
IF (Kdf <= 0.0) THEN
Dintegral := 0.0;
Out := 0.0;
ELSE
Out := (In - Dintegral) * Kdf;
Dintegral := Dintegral + (Ts * Out);
END_IF;

(*
 Внутренняя схема фильтра.

          Вычитание   Умножение
            +---+     +------+
 In ----->--| + |     |      |
            |   |-->--| *Kdf |-->----+-->-- Out
      +-->--| - |     |      |       |
      |     +---+     +------+       |
      |                              |
      |              Интегрирование  |
      |              +----------+    |
      |   Dintegral  |  Ts * z  |    |
      +--------------| -------- |----+
                     |   z - 1  |
                     +----------+

 Условное графическое обозначение (приближенное).

    +-----------------+
    |        s        |
 ->-| --------------- |->-
    | (1/Kdf) * s + 1 |
    +-----------------+

 Электрическая схема фильтра.

 +    || C            +
 o----||----o---------o
      ||    |          
  U In      |     U Out
           +-+         
           | | R       
           | |         
           +-+         
            |          
 -          |         -
 o----------o---------o
 Tf = 1/Kdf = R * C ([с] = [Ом] * [Ф])

 Временная характеристика.

 ^ Out
 |
 1*            Y(t) = 0 - exp(-(t/Tf))
 | *          
 |  *        
 |    *       
 |      *     
 0---------***---> t[s]

 ^ In
 |
 1************ X(t) = 1
 |            
 |            
 |            
 |            
 0---------------> t[s]

@COPYLEFT ALL WRONGS RESERVED :)
Author: VA
Contacts: DIY.PLC.314@gmail.com
Date start LIB_PLC: 2014
License: GNU GPL-2.0-or-later
https://www.gnu.org/licenses/old-licenses/gpl-2.0.html
https://www.youtube.com/watch?v=n1F_MfLRlX0
https://www.youtube.com/@DIY_PLC
https://github.com/DIYPLC/LIB_PLC
https://oshwlab.com/diy.plc.314/PLC_HW1_SW1
https://3dtoday.ru/3d-models/mechanical-parts/body/korpus-na-din-reiku
https://t.me/DIY_PLC
*)

END_FUNCTION_BLOCK


(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/LIB_PLC' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
FUNCTION_BLOCK FbDispersion (* Дисперсия PV. *)

VAR_INPUT
	In:REAL := 0.0; (* Вход измерения. *)
END_VAR

VAR_OUTPUT
	Variance  :REAL := 0.0; (* Дисперсия. *)
	Deviation :REAL := 0.0; (* Среднеквадратическое отклонение. *)
	Mean      :REAL := 0.0; (* Математическое ожидание (Среднее арифметическое). *)
END_VAR

VAR
	Buffer1: ARRAY [0..NUMBER] OF REAL; (* Буфер. *)
	Counter1:INT := 0; (* Счетчик. *)
	Summator:REAL := 0.0; (* Сумматор. *)
END_VAR

VAR CONSTANT
	NUMBER :INT := 99; (* Размер массива 100. *)
END_VAR

(* @END_DECLARATION := '0' *)
(*
 Дисперсия PV.
       DbDispersion
     +--------------+
     | FbDispersion |
  ->-|In    Variance|->-
     |     Deviation|->-
     |          Mean|->-
     +--------------+
*)

(* Обновление массива. *)
FOR Counter1 := NUMBER TO 1 BY -1 DO
Buffer1[Counter1] := Buffer1[Counter1 - 1];
END_FOR;
Buffer1[0] := In;

(* Расчет математического ожидания (среднего арифметического). *)
Summator := 0.0;
FOR Counter1 := 0 TO NUMBER BY 1 DO
Summator := Summator + Buffer1[Counter1];
END_FOR;
Mean := Summator /(INT_TO_REAL(NUMBER + 1));

(* Рассчет дисперсии. *)
Summator := 0.0;
FOR Counter1 := 0 TO NUMBER BY 1 DO
Summator := Summator + ((Buffer1[Counter1] - Mean) * (Buffer1[Counter1] - Mean));
END_FOR;
Variance := Summator / (INT_TO_REAL(NUMBER + 1));

(* Рассчет среднеквадратического отклонения. *)
Deviation := SQRT(Variance);

(*
@COPYLEFT ALL WRONGS RESERVED :)
Author: VA
Contacts: DIY.PLC.314@gmail.com
Date start LIB_PLC: 2014
License: GNU GPL-2.0-or-later
https://www.gnu.org/licenses/old-licenses/gpl-2.0.html
https://www.youtube.com/watch?v=n1F_MfLRlX0
https://www.youtube.com/@DIY_PLC
https://github.com/DIYPLC/LIB_PLC
https://oshwlab.com/diy.plc.314/PLC_HW1_SW1
https://3dtoday.ru/3d-models/mechanical-parts/body/korpus-na-din-reiku
https://t.me/DIY_PLC
*)
END_FUNCTION_BLOCK


(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/LIB_PLC' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
FUNCTION_BLOCK FbDriverAi420 (* Драйвер аналогово входа 4...20мА. *)

VAR_INPUT
	ADC      :WORD := 0    ; (* АЦП Сигнал от датчика 0...27648. *)
	OutMax   :REAL := 100.0; (* Диаппазон датчика максимум. *)
	OutMin   :REAL := 0.0  ; (* Диаппазон датчика минимум. *)
	ErrValue :REAL := 0.0  ; (* Значение для Out при ошибке датчика. *)
	SimValue :REAL := 0.0  ; (* Значение для Out при симуляции. *)
	SimOn    :BOOL := FALSE; (* Включить симуляцию. *)
END_VAR

VAR_OUTPUT
	Out   :REAL := 0.0  ; (* Выход в единицах датчика. *)
	I_mA  :REAL := 0.0  ; (* Ток на аналоговом входе 4...20мА. *)
	Error :BOOL := FALSE; (* Ошибка аналогово входа или датчика. *)
END_VAR
(* @END_DECLARATION := '0' *)
(*
 Драйвер аналогово входа 4...20мА.
            DbDriverAi420
    +---------------------------+
    |       FbDriverAi420       |
 ->-|ADC                     Out|->-
   -|OutMax                 I_mA|-
   -|OutMin                Error|-
   -|ErrValue                   |
   -|SimValue                   |
   -|SimOn                      |
    +---------------------------+
*)

(* Ошибка аналогово входа или датчика. *)
Error := (ADC = 16#7FFF) OR (ADC = 16#8000); (* 32767,-32768  *)

(* Ток на аналоговом входе 4...20мА. *)
IF (Error) THEN
I_mA := 0.0;
ELSE
(* Масштабирование 0...27648 [АЦП] -> 4...20[мА] *)
I_mA := ((INT_TO_REAL(WORD_TO_INT(ADC)) * 16.0 ) / 27648.0) + 4.0;
END_IF;

IF (SimOn) THEN (* Включена симуляция. *)
Out := SimValue; (* Значение для Out при симуляции. *)
ELSE
    IF (Error) THEN (* Ошибка аналогово входа или датчика. *)
    Out := ErrValue; (* Значение для Out при ошибке датчика. *)
    ELSE
    (* Масштабирование 4...20[мА] -> OutMin...OutMax *)
    Out := (OutMax - OutMin) * ((I_mA - 4.0) / 16.0) + OutMin;
    END_IF;
END_IF;

(* Амплитудный ограничитель диапазона датчика OutMin...OutMax *)
IF (Out >= OutMax) THEN (* Ограничение выхода сверху. *)
Out := OutMax; 
ELSE
    IF (Out <= OutMin) THEN (* Ограничение выхода снизу. *)
    Out := OutMin;
    ELSE
    (* Выход без ограничений. *)
    Out := Out;
    END_IF;
END_IF;

(*
Описание работы драйвера аналогово входа 4...20мА.
1.Сначала сигнал с АЦП 0...27648 преобразуется в токовый сигна 4...20мА.
2.Если не включена симуляция и нет ошибок сигнал 4...20мА преобразуется в сигнал датчика OutMin...OutMax.
3.Сигнал датчика ограничивается в пределах его диаппазона измерения OutMin...OutMax.

@COPYLEFT ALL WRONGS RESERVED :)
Author: VA
Contacts: DIY.PLC.314@gmail.com
Date start LIB_PLC: 2014
License: GNU GPL-2.0-or-later
https://www.gnu.org/licenses/old-licenses/gpl-2.0.html
https://www.youtube.com/watch?v=n1F_MfLRlX0
https://www.youtube.com/@DIY_PLC
https://github.com/DIYPLC/LIB_PLC
https://oshwlab.com/diy.plc.314/PLC_HW1_SW1
https://3dtoday.ru/3d-models/mechanical-parts/body/korpus-na-din-reiku
https://t.me/DIY_PLC
*)
END_FUNCTION_BLOCK


(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/LIB_PLC' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
FUNCTION_BLOCK FbDriverAo420 (* Драйвер аналогово выхода 4...20мА. *)

VAR_INPUT
	In       :REAL := 0.0  ; (* Вход сигнала на исполнительный механизм. *)
	InMax    :REAL := 100.0; (* Исполнительный механизм максимум. *)
	InMin    :REAL := 0.0  ; (* Исполнительный механизм минимум. *)
	SimValue :REAL := 0.0  ; (* Значение для исполнительного механизма при симуляции. *)
	SimOn    :BOOL := FALSE; (* Включить симуляцию. *)
END_VAR

VAR_OUTPUT
	DAC  :WORD := 0  ; (* ЦАП Сигнал на исполнительный механизм 0...27648. *)
	I_mA :REAL := 0.0; (* Ток на аналоговом выходе 4...20мА. *)
END_VAR

VAR
	InLim   :REAL := 0.0; (* Сигнал исполнительного механизма после ограничения. *)
	Switch1 :REAL := 0.0; (* Переключатель. *)
END_VAR
(* @END_DECLARATION := '0' *)
(*
 Драйвер аналогово выхода 4...20мА.
          DbDriverAo420
    +-----------------------+
    |     FbDriverAo420     |
 ->-|In                  DAC|->-
   -|InMax              I_mA|-
   -|InMin                  |
   -|SimValue               |
   -|SimOn                  |
    +-----------------------+
*)

(* Амплитудный ограничитель диапазона исполнительного механизма InMin...InMax *)
IF (In >= InMax) THEN (* Ограничение выхода сверху. *)
InLim := InMax; 
ELSE
    IF (In <= InMin) THEN (* Ограничение выхода снизу. *)
    InLim := InMin;
    ELSE
    (* Выход без ограничений. *)
    InLim := In;
    END_IF;
END_IF;

IF (SimOn) THEN (* Включена симуляция. *)
Switch1 := SimValue;
ELSE
Switch1 := InLim;
END_IF;

(* ЦАП Сигнал на исполнительный механизм 0...27648. *)
(* Масштабирование InMin...InMax -> 0...27648 *)
DAC := INT_TO_WORD( REAL_TO_INT( ((Switch1 - InMin) / (InMax - InMin)) * 27648.0) );

(* Ток на аналоговом выходе 4...20мА. *)
IF (InMax = InMin) THEN (* Защита от деления на 0. *)
I_mA := 0.0;
ELSE
(* Масштабирование InMin...InMax -> 4...20[мА] *)
I_mA := (((InLim - InMin) / (InMax - InMin)) * 16.0) + 4.0;
END_IF;

(*
Описание работы драйвера аналогово входа 4...20мА.
1.Сигнал исполнительного механизма ограничивается в пределах его диаппазона измерения InMin...InMax.
2.Если не включена симуляция сигнал c входа In преобразуется в сигнал ЦАП.
3.Если включена симуляция сигнал c входа SimValue преобразуется в сигнал ЦАП.
4.Рассчитывается значение тока 4...20мА для индикации.

@COPYLEFT ALL WRONGS RESERVED :)
Author: VA
Contacts: DIY.PLC.314@gmail.com
Date start LIB_PLC: 2014
