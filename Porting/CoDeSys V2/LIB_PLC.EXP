END_VAR
(* @END_DECLARATION := '0' *)
(*
 Драйвер дискретного выхода.
          DbDriverDo
    +--------------------+
    |     FbDriverDo     |
 ->-|In               Out|->-
   -|SimValue            |
   -|SimOn               |
    +--------------------+
*)

IF (SimOn) THEN
(* Симуляция включена. *)
(* Режим используется для отладки и при нештатной работе. *)
Out := SimValue;
ELSE
(* Симуляция выключена. *)
(* Штатный режим работы. *)
Out := In;
