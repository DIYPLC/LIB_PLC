(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/LIB_PLC' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
FUNCTION_BLOCK FbTOF (* Таймер с задержкой на выключение. *)

VAR_INPUT
	In           :BOOL := FALSE; (* Вход таймера. *)
	TimeDelayOff :UDINT := 5000 ; (* Время задержки выключения [мс]. *)
	Ts_ms        :UDINT := 100  ; (* Шаг дискретизации по времени [мс]. *)
END_VAR

VAR_OUTPUT
	Out :BOOL := FALSE; (* Выход таймера. *)
END_VAR

VAR
	Timer1 :UDINT := 0; (* Текущее время таймер1 [мс]. *)
END_VAR
(* @END_DECLARATION := '0' *)
(*
 Таймер с задержкой на выключение.
          DbTOF
    +----------------+
    |     FbTOF      |
 ->-|In           Out|->-
   -|TimeDelayOff    |
   -|Ts_ms           |
    +----------------+
*)

IF (TimeDelayOff > 0) THEN (* Таймер включен. *)
  IF (In) THEN (* На входе 1 то на выходе тоже 1. *)
  Out := TRUE;
  Timer1 := 0;   
  ELSE (* Если на входе 0. *)
    IF (Out) THEN (* На выходе 1. *)
      IF (Timer1 >= TimeDelayOff) THEN (* Задержка включения закончилась. *)
      Out := FALSE;
      Timer1 := 0;
      ELSE (* Задержка включения активна. *)
      Out := TRUE;
      Timer1 := Timer1 + Ts_ms;
      END_IF;
    ELSE (* На выходе 0. *)
    Out := FALSE;
    Timer1 := 0;
    END_IF;
  END_IF;
ELSE (* Таймер выключен. *)
Out := In;
Timer1 := 0;
END_IF;

(*
 Применение.

 Блок может применятся как фильтр дребезга контактов и как расширитель импульсов.

 Временная характеристика.

  In
  ^
  |     TimeDelayOff          TimeDelayOff
  |       |<--->|               |<--->|
 1|   *****     |     ***** *** *     |
  |   *   *     |     *   * * * *     |
 0*****---*************---***-*************----> t[s]

  Out
  ^
  |     TimeDelayOff          TimeDelayOff
  |       |<--->|               |<--->|
 1|   ***********     *****************
  |   *         *     *               *
 0*****---------*******---------------*****----> t[s]

@COPYLEFT ALL WRONGS RESERVED :)
Author: VA
Contacts: DIY.PLC.314@gmail.com
Date start LIB_PLC: 2014
