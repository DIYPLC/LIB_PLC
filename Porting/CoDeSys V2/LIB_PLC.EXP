https://3dtoday.ru/3d-models/mechanical-parts/body/korpus-na-din-reiku
https://t.me/DIY_PLC
*)
END_FUNCTION_BLOCK


(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/LIB_PLC' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
FUNCTION_BLOCK FbDelayN (* Блок задержки сигнала на 100 тактов. *)

VAR_INPUT
	In :REAL := 0.0; (* Вход. *)
END_VAR

VAR_OUTPUT
	Out :REAL := 0.0; (* Выход. *)
END_VAR

VAR
	Buffer1: ARRAY [0..NUMBER] OF REAL; (* Буфер задержки сигнала. *)
	Counter1 :INT := 0; (* Счетчик. *)
END_VAR

VAR CONSTANT
	NUMBER :INT := 98; (* Размер массива Тактов 100 - 2 = 98. *)
END_VAR

(* @END_DECLARATION := '0' *)
(*
 Блок задержки сигнала на 100 тактов.
      DbDelayN
    +----------+
    | FbDelayN |
 ->-|In     Out|->-
    +----------+
*)

(* W(Z)=Z^(-N), N=NUMBER+2 *)
Out := Buffer1[NUMBER];
FOR Counter1 := NUMBER TO 1 BY -1 DO
Buffer1[Counter1] := Buffer1[Counter1 - 1];
END_FOR;
Buffer1[0] := In;

(*
