(* @NESTEDCOMMENTS := 'Yes' *)
(* @PATH := '\/LIB_PLC' *)
(* @OBJECTFLAGS := '0, 8' *)
(* @SYMFILEFLAGS := '2048' *)
FUNCTION_BLOCK FbDriverDi

VAR_INPUT
	In       :BOOL := FALSE; (* Дискретный вход ПЛК. *)
	SimValue :BOOL := FALSE; (* Значение для Out при симуляции. *)
	SimOn    :BOOL := FALSE; (* Включить симуляцию. *)
END_VAR

VAR_OUTPUT
	Out :BOOL := FALSE; (* Выход дискретного сигнала. *)
END_VAR
(* @END_DECLARATION := '0' *)
(*
 Драйвер дискретного входа.
          DbDriverDi
    +--------------------+
    |     FbDriverDi     |
 ->-|In               Out|->-
   -|SimValue            |
   -|SimOn               |
    +--------------------+
*)

IF (SimOn) THEN
(* Симуляция включена. *)
(* Режим используется для отладки и при нештатной работе. *)
Out := SimValue;
ELSE
(* Симуляция выключена. *)
(* Штатный режим работы. *)
Out := In;
END_IF;

